{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "paths": {
      "@bh/shared": ["../shared/index.ts"]
    }
  },
  "include": ["index.ts", "lib", "tests", "prisma"]
}
